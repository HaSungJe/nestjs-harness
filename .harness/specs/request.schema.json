{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Request 파일 frontmatter 유효성 스키마",
  "type": "object",
  "required": ["feature_goal", "domain", "api_method", "api_path", "affected_tables"],
  "properties": {
    "feature_goal": {
      "type": "string",
      "minLength": 1,
      "description": "기능 목표"
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "description": "대상 도메인 (예: user, board)"
    },
    "api_method": {
      "type": "string",
      "enum": ["GET", "POST", "PATCH", "PUT", "DELETE"],
      "description": "HTTP 메서드"
    },
    "api_path": {
      "type": "string",
      "minLength": 1,
      "description": "API 경로 (예: /api/v1/user/sign)"
    },
    "affected_tables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "영향받는 테이블 목록"
    }
  }
}
