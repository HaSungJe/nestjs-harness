{
  "project_name": "nestjs-harness",
  "harness_rules": {
    "step_0_required_fields": ["feature_goal", "domain", "api_method", "api_path", "affected_tables"],
    "step_5_fail_retry_limit": 10,
    "enforced_docs": [
      "docs/architecture.md",
      "docs/entity.md",
      "docs/repository.md",
      "docs/error-handling.md",
      "docs/swagger-dto.md"
    ],
    "test_spec_path": "src/api/v1/<domain>/test/<feature>.spec.ts"
  }
}
