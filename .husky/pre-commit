if command -v gitleaks &> /dev/null; then
    gitleaks protect --staged --redact
    if [ $? -ne 0 ]; then
        echo "[Gitleaks] 시크릿이 감지되었습니다. 커밋이 차단되었습니다."
        exit 1
    fi
else
    echo "[Gitleaks] gitleaks가 설치되어 있지 않습니다. 시크릿 검사를 건너뜁니다."
fi

# src 또는 spec 이 staged 된 경우에만 전체 테스트 실행 (회귀 보장).
# 순수 문서·설정·husky 메타 커밋은 건너뜀.
if git diff --cached --name-only | grep -qE '^src/.*\.ts$|\.spec\.ts$'; then
    npm test
else
    echo "[Test] src/ 및 spec 변경이 없어 테스트를 건너뜁니다."
fi
